{
  "name": "healthpartner-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prestart": "npm run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "prisma:generate": "prisma generate",
    "db:init": "tsx prisma/init.ts",
    "db:seed": "prisma db seed",
    "db:reset": "tsx prisma/reset.ts",
    "test:server": "tsx src/server.ts",
    "test:unit": "tsx --test tests/unit/**/*.test.ts",
    "test:api": "playwright test",
    "test:api:ci": "npm run db:reset && playwright test"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/express-session": "^1.19.0",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.19.0",
    "luxon": "^3.4.4",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/express": "^4.17.21",
    "@types/luxon": "^3.4.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.14.0",
    "tsx": "^4.16.2",
    "typescript": "^5.6.3"
  }
}
